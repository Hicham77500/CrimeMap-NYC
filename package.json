{
  "name": "crimemap-nyc",
  "private": true,
  "scripts": {
    "start": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"red,blue\" \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && c:/python312/python.exe -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "frontend": "cd frontend && npm run dev",
    "install:all": "pip install -r backend/requirements.txt && cd frontend && npm install --legacy-peer-deps"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
